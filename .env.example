# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/auth_service?schema=public"

# Feature flags
CRYPTO_ENABLED=false
OIDC_ENABLED=false
LOG_FORMAT="pretty"

# Encryption (32-byte base64 keys)
SESSION_ENC_KEY=""
SESSION_ENC_KEY_ID="v1"
HEADER_SIGNING_KEY=""
HEADER_SIGNING_KEY_ID="v1"

# ZITADEL OIDC
ZITADEL_ISSUER="https://issuer.zitadel.example"
ZITADEL_CLIENT_ID="your-client-id"
ZITADEL_CLIENT_SECRET=""
ZITADEL_REDIRECT_URI="http://localhost:3000/callback"
ZITADEL_POST_LOGOUT_REDIRECT_URI="http://localhost:3000"
ZITADEL_SCOPES="openid profile email offline_access"
OIDC_ALLOW_INSECURE_HTTP=false

# ZITADEL Management API (org onboarding)
ZITADEL_API_BASE_URL="http://localhost:8080"
ZITADEL_API_TOKEN=""
ZITADEL_MASTER_PROJECT_ID=""
ZITADEL_PROJECT_GRANT_ROLE_KEYS="admin,user"
ZITADEL_ADMIN_ROLE_KEY="admin"
ZITADEL_USER_ROLE_KEY="user"

# Session cookie
SESSION_COOKIE_NAME="auth_session"
SESSION_COOKIE_DOMAIN=""
SESSION_COOKIE_PATH="/"
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE="lax"
SESSION_COOKIE_MAX_AGE_SEC=604800

# Queue / Redis
REDIS_URL="redis://localhost:6380/0"

# Gateway proxy
INTERNAL_API_BASE_URL="http://localhost:3001"
